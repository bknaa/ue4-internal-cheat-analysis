   180044f54:	48 89 5c 24 08       	mov    QWORD PTR [rsp+0x8],rbx
   180044f59:	48 89 74 24 10       	mov    QWORD PTR [rsp+0x10],rsi
   180044f5e:	57                   	push   rdi
   180044f5f:	48 83 ec 20          	sub    rsp,0x20
